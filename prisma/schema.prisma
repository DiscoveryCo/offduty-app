generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  googleId           String?   @unique
  createdAt          DateTime  @default(now())
  hasOnboarded       Boolean   @default(false)
  // Billing
  stripeCustomerId   String?   @unique
  subscriptionStatus String    @default("trialing") // trialing | active | past_due | canceled
  trialEndsAt        DateTime?
  currentPeriodEnd   DateTime?
  inboxes            Inbox[]
}

model Inbox {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String    @unique
  name         String?
  image        String?
  googleId     String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  isActive           Boolean   @default(false)
  pausedUntil        DateTime?
  trialEndsAt        DateTime?
  scheduledRemovalAt DateTime?
  holdLabelId        String?
  historyId    String?
  watchExpiry  DateTime?
  isPrimary    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  settings     Settings?
  schedules    Schedule[]
  vipRules     VipRule[]
  activityLogs ActivityLog[]
}

model Settings {
  id            String   @id @default(cuid())
  inboxId       String   @unique
  inbox         Inbox    @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  scheduleType  String   @default("custom_weekly")
  intervalHours Int?
  timesPerDay   Int?
  dndEnabled    Boolean  @default(false)
  dndFrom       String?
  dndTo         String?
  timezone      String   @default("UTC")
  updatedAt     DateTime @updatedAt
}

model Schedule {
  id        String @id @default(cuid())
  inboxId   String
  inbox     Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  time      String
}

// VipRule.type is one of: DOMAIN | EMAIL | KEYWORD
model VipRule {
  id      String @id @default(cuid())
  inboxId String
  inbox   Inbox  @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  type    String
  value   String
}

model ActivityLog {
  id          String   @id @default(cuid())
  inboxId     String
  inbox       Inbox    @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  deliveredAt DateTime @default(now())
  emailCount  Int
  slotTime    String?
}
